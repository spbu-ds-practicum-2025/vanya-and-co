# --- ДАННЫЕ ПОЛЬЗОВАТЕЛЕЙ И ФАЙЛЫ ---

# Файлы с данными пользователей
services/auth/data/*.json
services/auth/data/*.db
services/auth/data/users_*.json

# Базы данных пользователей
*.db
*.sqlite
*.sqlite3

# Файлы пользователей
services/file/data/
services/file/data/*
!services/file/data/.gitkeep

# Временные данные и кэш
/tmp/
/var/tmp/

# Специфичные файлы для вашего проекта
services/sharing/data/*.db
services/sharing/data/sharing.db

# Node директории (если используются)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

