.DS_Store
.AppleDouble
.LSOverride

# Linux
*~

# Windows
[Dd]esktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msm
*.msp

# Visual Studio Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.history

# Исключаем данные, но сохраняем структуру
services/auth/data/*
!services/auth/data/.gitkeep

services/file/data/*
!services/file/data/.gitkeep

services/sharing/data/*
!services/sharing/data/.gitkeep

# Для реплик файлов
services/file/data/node*/
!services/file/data/node*/.gitkeep